# Скопируй в .env и заполни своими значениями
# .env в gitignore, не коммитим

# Токен бота от @BotFather
TELEGRAM_BOT_TOKEN=

# Username бота (без @), для удобства логов
TELEGRAM_BOT_NAME=

# Твой numeric chat_id (узнать через @userinfobot)
# Только сообщения с этого chat_id будут обрабатываться (allowlist)
TELEGRAM_CHAT_ID=

# Таймаут ожидания ответа от пользователя (секунды)
# Если за это время не нажал Allow/Deny - hook вернёт block
APPROVAL_TIMEOUT=300
